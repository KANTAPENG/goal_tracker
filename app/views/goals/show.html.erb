<div class="d-flex justify-content-between align-items-center mb-4">
  <h1><%= @goal.title %></h1>
  <div>
    <%= link_to "編輯", edit_goal_path(@goal), class: "btn btn-secondary" %>
    <%= link_to "返回列表", goals_path, class: "btn btn-outline-secondary" %>
  </div>
</div>

<div class="card">
  <div class="card-body">
    <div class="mb-3">
      <h5 class="card-title">描述</h5>
      <p class="card-text">
        <% if @goal.description.present? %>
          <%= simple_format(@goal.description) %>
        <% else %>
          <em class="text-muted">無描述</em>
        <% end %>
      </p>
    </div>

    <div class="row mb-3">
      <div class="col-md-6">
        <h5>狀態</h5>
        <span class="badge bg-<%= @goal.status == 'completed' ? 'success' : @goal.status == 'in_progress' ? 'warning' : 'secondary' %> fs-6">
          <%= @goal.status == 'not_started' ? '未開始' : @goal.status == 'in_progress' ? '進行中' : '已完成' %>
        </span>
      </div>
      <div class="col-md-6">
        <h5>截止日期</h5>
        <p class="mb-0"><%= @goal.deadline.strftime("%Y年%m月%d日") %></p>
      </div>
    </div>

    <div class="mt-4">
      <h5>進度</h5>
      <p class="mb-2"><%= @goal.progress_percentage %>%</p>

      <div class="progress" style="height: 10px;">
        <div
          class="progress-bar bg-success"
          role="progressbar"
          style="width: <%= @goal.progress_percentage %>%"
          aria-valuenow="<%= @goal.progress_percentage %>"
          aria-valuemin="0"
          aria-valuemax="100">
        </div>
      </div>
    </div>

    <div class="mt-4">
      <%= link_to "刪除目標", @goal, data: { turbo_method: :delete, turbo_confirm: "確定要刪除這個目標嗎？" }, class: "btn btn-danger" %>
    </div>
  </div>
</div>

<div class="card mt-4">
  <div class="card-body">
    <h5 class="card-title">子目標</h5>

    <% if @goal.subtasks.any? %>
      <ul class="list-group mb-3 subtask-list" data-controller="sortable">
        <% @goal.subtasks.order(:position).each do |subtask| %>
          <li
            class="list-group-item subtask-item justify-content-between align-items-center"
            data-id="<%= subtask.id %>">
            <div class="d-flex align-items-center gap-2 flex-grow-1">
              <span class="text-muted" data-drag-handle style="cursor: grab;">☰</span>

              <div class="form-check mb-0">
                <%= form_with model: [@goal, subtask], method: :patch, local: true do |f| %>
                  <%= f.check_box :completed,
                    checked: subtask.completed,
                    class: "form-check-input me-2",
                    onchange: "this.form.submit()" %>

                  <%= f.label :completed, subtask.title,
                    class: "form-check-label #{subtask.completed ? 'text-decoration-line-through text-muted' : ''}" %>
                <% end %>
              </div>
            </div>

            <%= link_to [@goal, subtask],
              data: { turbo_method: :delete, turbo_confirm: "確定刪除？" },
              class: "btn btn-sm btn-outline-danger" do %>
              <i class="bi bi-trash3"></i>
            <% end %>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="text-muted">還沒有子目標</p>
    <% end %>

    <h6>新增子目標</h6>

    <%= form_with(model: [@goal, Subtask.new], local: true) do |f| %>
      <div class="input-group">
        <%= f.text_field :title, class: "form-control", placeholder: "輸入子目標..." %>
        <button class="btn btn-primary">新增</button>
      </div>
    <% end %>
  </div>
</div>
