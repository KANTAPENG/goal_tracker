<div class="d-flex justify-content-between align-items-center mb-4">
  <h1>我的目標</h1>
  <%= link_to "新增目標", new_goal_path, class: "btn btn-primary" %>
</div>

<% if @goals.any? %>
  <div class="row">
    <% @goals.each do |goal| %>
      <div class="col-md-6 col-lg-4 mb-4">
        <div class="card h-100">
          <div class="card-body">
            <h5 class="card-title">
              <%= link_to goal.title, goal, class: "text-decoration-none" %>
            </h5>
            <p class="card-text">
              <% if goal.description.present? %>
                <%= truncate(goal.description, length: 100) %>
              <% else %>
                <em class="text-muted">無描述</em>
              <% end %>
            </p>
            <div class="mb-2">
              <span class="badge bg-<%= goal.status == 'completed' ? 'success' : goal.status == 'in_progress' ? 'warning' : 'secondary' %>">
                <%= goal.status == 'not_started' ? '未開始' : goal.status == 'in_progress' ? '進行中' : '已完成' %>
              </span>
            </div>
            <p class="card-text">
              <small class="text-muted">
                <strong>截止日期：</strong><%= goal.deadline.strftime("%Y年%m月%d日") %>
              </small>
            </p>
          </div>
          <div class="card-footer bg-transparent">
            <div class="btn-group" role="group">
              <%= link_to "查看", goal, class: "btn btn-sm btn-outline-primary" %>
              <%= link_to "編輯", edit_goal_path(goal), class: "btn btn-sm btn-outline-secondary" %>
              <%= link_to "刪除", goal, data: { turbo_method: :delete, turbo_confirm: "確定要刪除這個目標嗎？" }, class: "btn btn-sm btn-outline-danger" %>
            </div>
          </div>
        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <div class="alert alert-info">
    <h4 class="alert-heading">還沒有目標！</h4>
    <p>開始追蹤您的目標吧！點擊上方「新增目標」按鈕來創建您的第一個目標。</p>
    <%= link_to "新增目標", new_goal_path, class: "btn btn-primary" %>
  </div>
<% end %>
